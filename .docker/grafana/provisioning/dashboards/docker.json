{
  "title": "Docker — Container Metrics",
  "uid": "docker-containers",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(dockerstats_cpu_usage_ratio, name)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "dockerstats_cpu_usage_ratio{name=~\"$container\"}",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "dockerstats_memory_usage_bytes{name=~\"$container\"}",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory Usage (%) do Limite",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "dockerstats_memory_usage_ratio{name=~\"$container\"} * 100",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Network Receive (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(dockerstats_network_received_bytes{name=~\"$container\"}[1m])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Network Transmit (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(dockerstats_network_transmitted_bytes{name=~\"$container\"}[1m])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Disk Read (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(dockerstats_blockio_read_bytes{name=~\"$container\"}[1m])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Disk Write (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(dockerstats_blockio_written_bytes{name=~\"$container\"}[1m])",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ]
    }
  ]
}
