    {
      "id": 1,
      "title": "Throughput Atual (req/s)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch-traces" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "req/min",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "alias": "req/min",
          "bucketAggs": [
            {
              "field": "@timestamp",
              "id": "2",
              "settings": { "interval": "1m", "min_doc_count": "0", "trimEdges": "0" },
              "type": "date_histogram"
            }
          ],
          "metrics": [{ "id": "1", "type": "count" }],
          "query": "kind:Server",
          "refId": "A",
          "timeField": "@timestamp"
        }
      ]
    },
